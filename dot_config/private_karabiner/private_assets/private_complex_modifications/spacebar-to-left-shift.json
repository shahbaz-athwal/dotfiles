{
  "title": "Spacebar to Left Shift when held",
  "rules": [
    {
      "description": "Change spacebar to left_shift. (Post spacebar if pressed alone)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "spacebar",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "set_variable": {
                "name": "spacebar_layer",
                "value": 1
              }
            },
            {
              "key_code": "left_shift",
              "lazy": true
            }
          ],
          "to_after_key_up": [
            {
              "set_variable": {
                "name": "spacebar_layer",
                "value": 0
              }
            }
          ],
          "to_if_alone": [
            {
              "key_code": "spacebar"
            }
          ]
        }
      ]
    }
  ]
}
