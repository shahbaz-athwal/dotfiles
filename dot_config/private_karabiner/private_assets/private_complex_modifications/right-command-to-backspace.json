{
  "title": "Right Command to Backspace",
  "rules": [
    {
      "description": "Map Right Cmd to Backspace",
      "manipulators": [
        {
          "description": "Right Cmd -> Backspace",
          "from": {
            "key_code": "right_command",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "delete_or_backspace"
            }
          ],
          "type": "basic"
        }
      ]
    }
  ]
}
